{
  "name": "kid-vibe-code",
  "version": "1.0.0",
  "description": "A kid-friendly vibe coding platform for ages 7-18",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "node --import=./server/instrument.js server/index.js",
    "start:prod": "NODE_ENV=production node --import=./server/instrument.js server/index.js",
    "start:local": "node server/index.js",
    "health": "curl -s http://localhost:3001/api/health | node -e \"process.stdin.on('data',d=>{const h=JSON.parse(d);console.log(h.status==='ok'?'OK':'FAIL',h);process.exit(h.status==='ok'?0:1)})\"",
    "docker:build": "docker build -t vibecodekidz .",
    "docker:run": "docker run -p 3001:3001 --env-file .env vibecodekidz",
    "test": "npx playwright test",
    "test:safety": "node server/tests/safety.test.js",
    "test:ci": "npm run test:safety && npx playwright test kid-bot",
    "test:gate62": "npx playwright test gate-6-2 --workers=1",
    "test:bot": "npx playwright test interactive-bot --headed",
    "test:all": "npx playwright test kid-bot --headed",
    "test:quick": "npx playwright test kid-bot --headed --grep=\"API health|gallery\"",
    "test:games": "npx playwright test game-builder-bot --headed --workers=1",
    "test:game1": "npx playwright test game-builder-bot --headed --grep=\"Game 1\"",
    "test:game2": "npx playwright test game-builder-bot --headed --grep=\"Game 2\"",
    "test:game3": "npx playwright test game-builder-bot --headed --grep=\"Game 3\"",
    "test:game4": "npx playwright test game-builder-bot --headed --grep=\"Game 4\"",
    "test:game5": "npx playwright test game-builder-bot --headed --grep=\"Game 5\"",
    "test:report": "npx playwright show-report",
    "lint": "eslint src/ server/",
    "lint:fix": "eslint src/ server/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"server/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"server/**/*.js\"",
    "prepare": "husky || true",
    "db:schema": "node scripts/run-schema.js",
    "db:seed-sprites": "node scripts/seed-sprites.js",
    "db:ingest-kenney": "node scripts/ingest-kenney-sprites.js",
    "db:migrate": "node scripts/migrate-to-postgres.js",
    "db:migrate:dry": "node scripts/migrate-to-postgres.js --dry-run",
    "db:migrate-consent-versioning": "node scripts/migrate-consent-versioning.js",
    "db:flag-stale-consents": "node scripts/flag-stale-consents.js",
    "db:migrate-passwords": "node scripts/migrate-passwords.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@monaco-editor/react": "^4.6.0",
    "@sentry/node": "^10.40.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "openai": "^6.22.0",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stripe": "^20.3.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "image-size": "^2.0.2",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint",
      "prettier --write"
    ],
    "server/**/*.js": [
      "eslint",
      "prettier --write"
    ]
  }
}
